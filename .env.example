# Provider selection
EMBEDDING_PROVIDER=gemini

# Shared embedding fallback
EMBEDDING_MODEL=

# Gemini / Google AI Studio
GEMINI_API_KEY=your_gemini_api_key_here
# Latest stable Gemini embedding model per Google docs (updated June 2025)
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_CHAT_MODEL=gemini-2.5-flash
# Optional lower-latency Gemini model for retrieval-query rewriting
GEMINI_RETRIEVAL_QUERY_MODEL=gemini-2.5-flash-lite
GEMINI_OUTPUT_DIMENSION=1536
GEMINI_MIN_REQUEST_INTERVAL_SECONDS=1.0

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4.1-mini

# Azure OpenAI
AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com
AZURE_OPENAI_CHAT_DEPLOYMENT=your_chat_deployment_name
AZURE_OPENAI_API_VERSION=2024-02-01

# Cohere (reranker)
COHERE_API_KEY=your_cohere_api_key_here

# KB answer and conversational model providers (preferred: Azure OpenAI + Gemini embeddings)
KB_ANSWER_PROVIDER=azure_openai
INTENT_CLASSIFIER_PROVIDER=azure_openai
ACTION_AGENT_PROVIDER=azure_openai
ACTION_EXTRACTION_PROVIDER=azure_openai
ESCALATION_AGENT_PROVIDER=azure_openai
# Fully Gemini mode is also supported:
# KB_ANSWER_PROVIDER=gemini
# INTENT_CLASSIFIER_PROVIDER=gemini
# ACTION_AGENT_PROVIDER=gemini
# ACTION_EXTRACTION_PROVIDER=gemini
# ESCALATION_AGENT_PROVIDER=gemini
# KB_ANSWER_SYSTEM_PROMPT=
# INTENT_CLASSIFIER_SYSTEM_PROMPT=

# Local test provider
# EMBEDDING_PROVIDER=local

# Qdrant
QDRANT_COLLECTION=customer_care_kb
QDRANT_DOCUMENT_COLLECTION=customer_care_documents_kb
QDRANT_EMBEDDING_DIMENSION=1536
QDRANT_DISTANCE=cosine
QDRANT_PATH=vector_db/qdrant/data/local
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_PREFER_GRPC=false

# Ingestion
FAQS_JSONL_PATH=data/faqs/high_quality_faqs.jsonl
DOCUMENTS_MANIFEST_PATH=data/documents/documents_manifest.json
FAQ_PIPELINE_BATCH_SIZE=3
DOCUMENT_PIPELINE_BATCH_SIZE=16
